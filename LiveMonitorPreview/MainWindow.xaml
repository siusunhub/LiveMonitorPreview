<Window x:Class="LiveMonitorPreview.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Monitor Preview" 
        Height="200" 
        Width="600"
        Background="#2D2D30"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        MouseDown="Window_MouseDown"
        MouseRightButtonUp="Window_MouseRightButtonUp">

    <Border BorderBrush="#007ACC" BorderThickness="1" CornerRadius="5">
        <Grid Margin="10">
            <ItemsControl Name="MonitorsItemsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Border Background="#3E3E42" 
                                    BorderBrush="#007ACC" 
                                    BorderThickness="1" 
                                    CornerRadius="5" 
                                    Margin="5"
                                    Padding="5"
                                    Width="{Binding CardWidth}"
                                    Height="{Binding CardHeight}"
                                    AllowDrop="True"
                                    MouseDown="MonitorBorder_MouseDown"
                                    Drop="MonitorBorder_Drop"
                                    DragOver="MonitorBorder_DragOver"
                                    Cursor="Hand">
                                <StackPanel>
                                    <TextBlock Text="{Binding DisplayName}" 
                                              Foreground="White" 
                                              FontWeight="Bold"
                                              HorizontalAlignment="Center"
                                              Margin="0,0,0,5"
                                              Visibility="{Binding NameVisibility}"/>
                                    <Image Source="{Binding Preview}" 
                                           Stretch="Uniform"/>
                                </StackPanel>
                            </Border>

                            <!-- Gray overlay when refresh is disabled -->
                            <Border Background="#80000000" 
                                    BorderBrush="#007ACC" 
                                    BorderThickness="1" 
                                    CornerRadius="5" 
                                    Margin="5"
                                    Visibility="{Binding DisabledOverlayVisibility}"
                                    IsHitTestVisible="False">
                                <TextBlock Text="REFRESH DISABLED" 
                                          Foreground="#CCCCCC" 
                                          FontWeight="Bold"
                                          FontSize="14"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Border>
</Window>